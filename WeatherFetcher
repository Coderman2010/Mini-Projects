from plyer import notification
import requests

url = "https://geocoding-api.open-meteo.com/v1/search"
params = {"name": "Mumbai", "count": 1}

# notification.notify(title="Test", message="hii")
response = requests.get(url, params=params).json()


lat = response["results"][0]["latitude"]
long = response["results"][0]["longitude"]

wurl = "https://api.open-meteo.com/v1/forecast"
wparams = {"latitude": lat, "longitude": long, "current_weather": True}
wres = requests.get(wurl, params=wparams).json()

# print(wres)
temp = wres["current_weather"]["temperature"]
wspeed = wres["current_weather"]["windspeed"]
print(f"temperature: {temp} winspeed: {wspeed}")
